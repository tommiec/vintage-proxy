TZ=Europe/Brussels

# Address at which the old browser reaches this host (IP or hostname).
# WebOne uses this for internal rewrites. Required — leave no placeholder.
# Example: PROXY_HOSTNAME=192.168.1.10
PROXY_HOSTNAME=

# Proxy service ports (host-side). Change only if there are port conflicts.
MACPROXY_PORT=5003
WEBONE_PORT=8091
CRYANC_PORT=8767
BROWSERVICE_PORT=8083

# AdGuard Home ports.
# Set ADGUARD_DNS_PORT=53 to use AdGuard as DNS on the G3 (requires host port 53 to be free).
# Default 5354 avoids conflicts with host DNS and mDNS/Bonjour (port 5353).
ADGUARD_DNS_PORT=5354
ADGUARD_SETUP_PORT=3080
ADGUARD_WEB_PORT=3001
